# RetainPDF Server Environment Variables
# Copy to .env and customize

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Storage paths (absolute or relative)
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
TEMP_DIR=./data/temp
JOB_DB=./data/jobs.db
LOG_DIR=./data/logs

# Original RetainPDF source location (used by pipeline adapter)
RETAIN_PDF_ROOT=./retain-pdf

# Translation
TRANSLATOR_PROVIDER=deepseek
TRANSLATOR_API_KEY=your-api-key-here
TRANSLATOR_BASE_URL=https://api.deepseek.com/v1
TRANSLATOR_MODEL=deepseek-chat

# OCR
OCR_PROVIDER=mineru
OCR_API_KEY=
OCR_ENABLED=true

# Pipeline tuning
MAX_UPLOAD_SIZE_MB=200
MAX_CONCURRENT_JOBS=2
TRANSLATION_MODE=sci
MATH_MODE=direct_typst
RENDER_MODE=typst
PDF_COMPRESS_DPI=150

# Defaults
DEFAULT_TARGET_LANG=zh
DEFAULT_SOURCE_LANG=

# Logging
LOG_LEVEL=INFO
